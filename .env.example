# =============================================================================
# VIETNAM ONLINE — Environment Configuration (copy to .env and fill values)
# Theo tai lieu: Chương 31-35 Infrastructure + Chương 17 Database Schema
# =============================================================================

# --- App ---
VNO_APP_ENV=development
VNO_DEFAULT_ZONE=HOI_AN
VNO_DEFAULT_LOCALE=vi
VNO_DEV_SKIP_AUTH=false

# --- Game Server (35.3) ---
VNO_GATEWAY_HOST=0.0.0.0
VNO_GATEWAY_PORT=8080
VNO_GAME_SERVER_TICK_HZ=20
VNO_POSITION_SYNC_MS=50
VNO_MAX_CCU_PER_ZONE=200
VNO_INTEREST_RADIUS_M=200
VNO_PROXIMITY_CHAT_RADIUS_M=50
VNO_CHECKPOINT_SAVE_SEC=30
VNO_RECONNECT_GRACE_SEC=60

# --- JWT Auth (FR-01, Chương 19) ---
VNO_JWT_SECRET=change-me-to-random-64-char-secret
VNO_JWT_ACCESS_TTL_MIN=15
VNO_JWT_REFRESH_TTL_DAYS=7

# --- PostgreSQL / Supabase (FR-10, 35.5) ---
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DB_PASSWORD=YOUR_PASSWORD

# --- Redis Cache (35.1 — session, leaderboard, weather cache) ---
REDIS_URL=redis://default:password@host:6379
REDIS_PASSWORD=

# --- Map / Cesium / OSM (FR-06, 3.2, 35.2.1) ---
VNO_ZONE_HOI_AN_LAT=15.8794
VNO_ZONE_HOI_AN_LNG=108.3294
CESIUM_ION_TOKEN=
OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter
MAP_TILE_CACHE_DIR=data/cache/tiles

# --- Weather API (doc L.1 — OpenWeatherMap, sync 15 phut) ---
OPENWEATHERMAP_API_KEY=
WEATHER_SYNC_INTERVAL_MIN=15

# --- NPC AI Layer 3 (13, 35.2.2) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
NPC_AI_DAILY_COST_CAP_USD=5.00

# --- Voice Chat (Phase 3) ---
VIVOX_SERVER=
VIVOX_DOMAIN=
VIVOX_ISSUER=
VIVOX_KEY=

# --- Analytics & Monitoring ---
SENTRY_DSN=
POSTHOG_API_KEY=
GRAFANA_URL=
PROMETHEUS_URL=

# --- CDN / Storage ---
CLOUDFLARE_ACCOUNT_ID=
SUPABASE_STORAGE_BUCKET=ugc-photos

# --- Payment (Phase 4) ---
MOMO_PARTNER_CODE=
VNPAY_TMN_CODE=
STRIPE_SECRET_KEY=

# --- Client prototype ---
VNO_SAVE_PATH=data/saves/save.dat
VNO_API_BASE_URL=http://localhost:8080
